<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.ww.mall</groupId>
        <artifactId>mall-grpc</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>mall-grpc-client</artifactId>
    <packaging>jar</packaging>

    <name>${project.artifactId}</name>
    <description>
        grpc 客户端 模块，test专用
    </description>

    <dependencies>
        <dependency>
            <groupId>com.ww.mall</groupId>
            <artifactId>mall-spring-boot-starter-web</artifactId>
            <version>${revision}</version>
            <exclusions>
                <exclusion>
                    <artifactId>caffeine</artifactId>
                    <groupId>com.github.ben-manes.caffeine</groupId>
                </exclusion>
                <exclusion>
                    <groupId>net.devh</groupId>
                    <artifactId>grpc-server-spring-boot-starter</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <!-- grpc-api -->
        <dependency>
            <groupId>com.ww.mall</groupId>
            <artifactId>mall-grpc-api</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- grpc-server -->
        <dependency>
            <groupId>net.devh</groupId>
            <artifactId>grpc-client-spring-boot-starter</artifactId>
        </dependency>
        <!-- rabbitmq starter -->
        <dependency>
            <groupId>com.ww.mall</groupId>
            <artifactId>mall-spring-boot-starter-rabbitmq</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- mongodb starter -->
        <dependency>
            <groupId>com.ww.mall</groupId>
            <artifactId>mall-spring-boot-starter-mongodb</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- websocket starter -->
        <dependency>
            <groupId>com.ww.mall</groupId>
            <artifactId>mall-spring-boot-starter-websocket</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>${project.artifactId}</finalName>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
