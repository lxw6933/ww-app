<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.ww.app</groupId>
        <artifactId>ww-mall</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>ww-order</artifactId>
    <description>订单服务</description>

    <dependencies>
        <!-- web通用服务依赖 -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-web</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- redis starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-redis</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- rabbitmq starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-rabbitmq</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- disruptor starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-disruptor</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- mongodb starter -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-mongodb</artifactId>
        </dependency>
        <!-- mybatis starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-mybatis</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>${project.artifactId}</finalName>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
