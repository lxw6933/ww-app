<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.ww.app</groupId>
        <artifactId>ww-mall</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>ww-seckill</artifactId>
    <description>秒杀服务</description>

    <dependencies>
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-web</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- grpc-client -->
        <dependency>
            <groupId>net.devh</groupId>
            <artifactId>grpc-client-spring-boot-starter</artifactId>
        </dependency>
        <!-- redis starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-redis</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- rabbitmq starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-rabbitmq</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- mongodb starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-mongodb</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- captcha -->
        <dependency>
            <groupId>com.github.whvcse</groupId>
            <artifactId>easy-captcha</artifactId>
        </dependency>
        <!-- excel starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-excel</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- ip2Region starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-ip</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- xxl job starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-job</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- minio starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-minio</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- sensitive starter -->
        <dependency>
            <groupId>com.ww.app</groupId>
            <artifactId>ww-spring-boot-starter-sensitive</artifactId>
            <version>${revision}</version>
        </dependency>
        <!-- test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>${project.artifactId}</finalName>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <version>${spring-boot.version}</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
